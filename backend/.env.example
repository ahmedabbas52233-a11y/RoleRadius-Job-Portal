# ── Django core ───────────────────────────────────────────────────────────────
# Generate a real key: python -c "import secrets; print(secrets.token_urlsafe(50))"
SECRET_KEY=your-secret-key-minimum-50-chars-change-this-now

DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1

# ── Database ──────────────────────────────────────────────────────────────────
# Option A: Connection URL (for Railway, Render, Heroku)
# DATABASE_URL=postgresql://user:password@host:5432/dbname

# Option B: Individual settings (for local development)
DB_NAME=roleradius_db
DB_USER=postgres
DB_PASSWORD=postgres
DB_HOST=localhost
DB_PORT=5432

# ── Cloudinary (file uploads in production) ───────────────────────────────────
# Leave empty to use local filesystem storage in development
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# ── Email ─────────────────────────────────────────────────────────────────────
# Development: console backend prints emails to terminal
EMAIL_BACKEND=django.core.mail.backends.console.EmailBackend

# Production: use SMTP (Gmail App Password recommended)
# EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
# EMAIL_HOST=smtp.gmail.com
# EMAIL_PORT=587
# EMAIL_HOST_USER=your@gmail.com
# EMAIL_HOST_PASSWORD=your-app-password-not-account-password
# DEFAULT_FROM_EMAIL=noreply@roleradius.com

# ── Frontend URL (used in email verification links) ───────────────────────────
FRONTEND_URL=http://localhost:5173

# ── CORS (separate multiple origins with commas) ──────────────────────────────
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000
CSRF_TRUSTED_ORIGINS=http://localhost:5173,http://localhost:3000
